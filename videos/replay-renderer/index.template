<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1920, height=1080" />
    <title>Macaron Session Replay</title>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
    <script>
      window.REPLAY_DATA = /*__REPLAY_DATA__*/;
    </script>
    <style>
      :root {
        color-scheme: light;
        --bg: #faf9f5;
        --surface: #ffffff;
        --surface-2: #f5f4ed;
        --surface-3: #efede3;
        --code-bg: #f5f4ed;
        --border: #e8e6dc;
        --border-strong: #d9d5c7;
        --text: #3d3929;
        --text-2: #5d584a;
        --muted: #8a8473;
        --muted-2: #b8b2a3;
        --accent: #c96442;
        --accent-hover: #b45533;
        --accent-soft: rgba(201, 100, 66, 0.1);
        --accent-soft-2: rgba(201, 100, 66, 0.18);
        --good: #5a8b5a;
        --warn: #b88a3a;
        --bad: #c0524a;
        --font-sans: "Sohne", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Helvetica, Arial, sans-serif;
        --font-serif: "Tiempos Text", "Copernicus", "Source Serif Pro", Georgia, "Times New Roman", serif;
        --font-mono: "Sohne Mono", ui-monospace, SFMono-Regular, "JetBrains Mono", Menlo, Consolas, monospace;
      }

      * {
        box-sizing: border-box;
        letter-spacing: 0;
      }

      html,
      body {
        width: 1920px;
        height: 1080px;
        margin: 0;
        overflow: hidden;
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-sans);
        -webkit-font-smoothing: antialiased;
      }

      code,
      pre,
      .mono {
        font-family: var(--font-mono);
        font-variant-ligatures: none;
      }

      #root {
        position: relative;
        width: 1920px;
        height: 1080px;
        overflow: hidden;
      }

      .clip {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
      }

      .frame-fill {
        position: absolute;
        inset: 0;
        display: grid;
        grid-template-columns: 260px minmax(0, 1fr);
        overflow: hidden;
        background: var(--bg);
      }

      .sidebar {
        position: relative;
        z-index: 3;
        height: 1080px;
        display: flex;
        flex-direction: column;
        gap: 30px;
        padding: 30px 20px 20px;
        border-right: 1px solid var(--border);
        background: var(--surface-2);
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 13px;
        padding: 2px 11px 6px;
        color: var(--text);
      }

      .brand-mark {
        width: 38px;
        height: 38px;
        display: block;
        flex: 0 0 auto;
        object-fit: contain;
      }

      .brand-name {
        font-family: var(--font-serif);
        font-size: 21px;
        line-height: 1.1;
      }

      .brand-sub {
        margin-top: 3px;
        color: var(--text-2);
        font-size: 13px;
      }

      .nav {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .nav-item {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: 12px 15px;
        border: 1px solid transparent;
        border-radius: 8px;
        color: var(--text-2);
      }

      .nav-item span {
        font-size: 17px;
        font-weight: 500;
      }

      .nav-item small {
        color: var(--text-2);
        font-size: 13px;
      }

      .nav-item.active {
        border-color: var(--border);
        background: var(--surface);
      }

      .nav-item.active span {
        color: var(--accent-hover);
      }

      .sidebar-section {
        padding: 0 12px;
      }

      .sidebar-label {
        margin-bottom: 12px;
        color: var(--text-2);
        font-family: var(--font-mono);
        font-size: 12px;
        text-transform: uppercase;
      }

      .agent-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--border);
      }

      .agent-avatar {
        width: 38px;
        height: 38px;
        display: grid;
        place-items: center;
        border-radius: 8px;
        background: var(--accent-soft);
        color: var(--accent-hover);
        font-size: 19px;
        font-weight: 700;
      }

      .agent-name {
        font-size: 16px;
        font-weight: 700;
      }

      .agent-role {
        margin-top: 2px;
        color: var(--text-2);
        font-size: 12px;
      }

      .sidebar-footer {
        margin-top: auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 12px;
        color: var(--text-2);
        font-size: 12px;
      }

      .runtime-status::before {
        width: 7px;
        height: 7px;
        display: inline-block;
        margin-right: 7px;
        border-radius: 50%;
        background: var(--good);
        content: "";
      }

      .sidebar-footer code {
        padding: 2px 7px;
        border: 1px solid var(--border);
        border-radius: 4px;
        background: var(--surface);
        font-size: 11px;
      }

      .main {
        position: relative;
        min-width: 0;
        height: 1080px;
        display: flex;
        flex-direction: column;
        padding: 26px 32px 20px;
        overflow: hidden;
      }

      .session-bar {
        height: 48px;
        display: flex;
        flex: 0 0 auto;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        padding: 8px 18px;
        margin-bottom: 18px;
        border: 1px solid var(--border);
        border-radius: 999px;
        background: var(--surface-2);
        font-size: 14px;
      }

      .session-bar-left,
      .session-bar-right {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
      }

      .crumb-link {
        color: var(--text-2);
      }

      .sep {
        color: var(--text-2);
      }

      .session-id {
        overflow: hidden;
        color: var(--text-2);
        font-family: var(--font-mono);
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .branch {
        padding: 2px 8px;
        border: 1px solid var(--border);
        border-radius: 4px;
        background: var(--surface);
        color: var(--text-2);
        font-family: var(--font-mono);
        font-size: 12px;
      }

      .live-state {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        color: var(--accent-hover);
        font-family: var(--font-mono);
        font-size: 19px;
        font-weight: 700;
      }

      .live-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--accent);
      }

      .workspace {
        min-height: 0;
        flex: 1 1 auto;
        display: grid;
        grid-template-columns: 650px minmax(0, 1fr);
        gap: 20px;
      }

      .thread-panel,
      .preview-panel {
        position: relative;
        min-width: 0;
        overflow: hidden;
        border: 1px solid var(--border);
        border-radius: 14px;
        background: var(--surface);
      }

      .panel-head {
        height: 62px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        padding: 0 22px;
        border-bottom: 1px solid var(--border);
      }

      .panel-title {
        color: var(--text);
        font-size: 16px;
        font-weight: 600;
      }

      .panel-subtitle {
        margin-top: 2px;
        color: var(--text-2);
        font-size: 12px;
      }

      .event-count {
        color: var(--text-2);
        font-family: var(--font-mono);
        font-size: 12px;
      }

      .feed-viewport {
        position: absolute;
        inset: 62px 0 0;
        overflow: hidden;
        padding: 20px 22px 0;
      }

      .session-head {
        display: flex;
        align-items: baseline;
        gap: 9px;
        padding: 4px 2px 14px;
        margin-bottom: 9px;
        border-bottom: 1px dashed var(--border);
        color: var(--text-2);
        font-family: var(--font-mono);
        font-size: 12px;
      }

      .session-head strong {
        color: var(--text-2);
        font-weight: 400;
      }

      .feed-stack {
        display: flex;
        flex-direction: column;
        gap: 4px;
        will-change: transform;
      }

      .event-entry {
        position: relative;
        flex: 0 0 76px;
        height: 76px;
        overflow: hidden;
        opacity: 0;
        will-change: transform, opacity;
      }

      .event-entry.user {
        display: flex;
        gap: 10px;
        padding: 8px 12px;
        border-radius: 8px;
        background: var(--surface-2);
      }

      .user-chev {
        flex: 0 0 auto;
        color: var(--accent-hover);
        font-size: 19px;
        font-weight: 700;
      }

      .event-copy {
        display: -webkit-box;
        overflow: hidden;
        color: var(--text);
        font-size: 14px;
        line-height: 1.45;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 3;
      }

      .event-entry.assistant {
        padding: 6px 3px;
      }

      .event-meta {
        margin-bottom: 4px;
        color: var(--text-2);
        font-family: var(--font-mono);
        font-size: 11px;
      }

      .event-entry.tool {
        padding: 6px 3px;
        font-family: var(--font-mono);
        font-size: 13px;
        line-height: 1.55;
      }

      .tool-head {
        display: flex;
        align-items: center;
        gap: 7px;
        min-width: 0;
      }

      .tool-dot {
        width: 7px;
        height: 7px;
        flex: 0 0 auto;
        border-radius: 50%;
        background: var(--good);
      }

      .tool-dot.warning {
        background: var(--warn);
      }

      .tool-dot.error {
        background: var(--bad);
      }

      .tool-name {
        color: var(--text);
        font-weight: 600;
      }

      .tool-input {
        min-width: 0;
        overflow: hidden;
        color: var(--text-2);
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .tool-time {
        margin-left: auto;
        color: var(--text-2);
      }

      .tool-out {
        display: flex;
        gap: 7px;
        padding-left: 11px;
        margin-top: 3px;
        color: var(--text-2);
      }

      .tool-rail {
        flex: 0 0 auto;
        color: var(--text-2);
      }

      .tool-result {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .event-entry.render_ui {
        padding: 8px 2px;
      }

      .genui-event-head {
        display: flex;
        align-items: center;
        gap: 8px;
        padding-bottom: 7px;
        color: var(--text-2);
      }

      .genui-event-dot {
        width: 7px;
        height: 7px;
        flex: 0 0 auto;
        border-radius: 50%;
        background: var(--accent);
      }

      .genui-event-label,
      .genui-streaming {
        flex: 0 0 auto;
        font-family: var(--font-mono);
        font-size: 11px;
      }

      .genui-event-code {
        min-width: 0;
        flex: 1 1 auto;
        overflow: hidden;
        color: var(--text-2);
        font-family: var(--font-mono);
        font-size: 11px;
        opacity: 0.7;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .genui-streaming {
        color: var(--accent-hover);
        font-weight: 600;
      }

      .event-progress-track {
        height: 4px;
        overflow: hidden;
        border-radius: 3px;
        background: var(--surface-3);
      }

      .event-progress {
        display: block;
        width: 100%;
        height: 100%;
        border-radius: 3px;
        background: var(--accent);
        transform: scaleX(0);
        transform-origin: 0 50%;
      }

      .preview-panel {
        background: var(--surface);
      }

      .preview-head-right {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--text-2);
        font-family: var(--font-mono);
        font-size: 11px;
      }

      .preview-head-right .genui-streaming {
        color: var(--accent-hover);
      }

      .preview-progress-track {
        position: absolute;
        z-index: 4;
        top: 61px;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--surface-3);
      }

      .preview-progress {
        display: block;
        width: 100%;
        height: 100%;
        background: var(--accent);
        transform: scaleX(0);
        transform-origin: 0 50%;
      }

      .preview-canvas {
        position: absolute;
        inset: 64px 0 0;
        overflow: hidden;
        padding: 24px;
        background: var(--bg);
      }

      .preview-empty {
        position: absolute;
        inset: 24px;
        display: grid;
        place-items: center;
        border: 1px dashed var(--border-strong);
        border-radius: 10px;
        color: var(--text-2);
        text-align: center;
      }

      .preview-empty strong {
        display: block;
        margin-bottom: 7px;
        color: var(--text-2);
        font-size: 18px;
        font-weight: 500;
      }

      .preview-empty span {
        font-size: 13px;
      }

      .genui-root {
        position: absolute;
        inset: 24px;
        overflow: hidden;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: var(--surface);
        opacity: 0;
        visibility: hidden;
      }

      .dashboard {
        height: 100%;
        display: flex;
        flex-direction: column;
        padding: 26px;
      }

      .dashboard-topline {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .dashboard-eyebrow {
        color: var(--accent-hover);
        font-family: var(--font-mono);
        font-size: 11px;
        font-weight: 600;
      }

      .dashboard-status {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        color: var(--text-2);
        font-family: var(--font-mono);
        font-size: 11px;
      }

      .dashboard-status::before {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--good);
        content: "";
      }

      .dashboard-title {
        margin: 12px 0 20px;
        color: var(--text);
        font-family: var(--font-serif);
        font-size: 36px;
        font-weight: 400;
        line-height: 1.15;
      }

      .stats-grid {
        min-height: 102px;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
      }

      .stat-card {
        height: 102px;
        padding: 14px 15px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface-2);
        opacity: 0;
        visibility: hidden;
      }

      .stat-label {
        color: var(--text-2);
        font-family: var(--font-mono);
        font-size: 11px;
        text-transform: uppercase;
      }

      .stat-value {
        margin-top: 10px;
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 25px;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
      }

      .stat-card.good .stat-value {
        color: var(--text);
      }

      .stat-card.warn .stat-value {
        color: var(--text);
      }

      .stat-card.bad .stat-value {
        color: var(--text);
      }

      .stat-card.good {
        border-top-color: var(--good);
      }

      .stat-card.warn {
        border-top-color: var(--warn);
      }

      .stat-card.bad {
        border-top-color: var(--bad);
      }

      .dashboard-body {
        min-height: 0;
        flex: 1 1 auto;
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: 12px;
        margin-top: 12px;
      }

      .data-section {
        min-width: 0;
        padding: 15px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface);
        opacity: 0;
        visibility: hidden;
      }

      .section-label {
        padding-bottom: 9px;
        margin-bottom: 8px;
        border-bottom: 1px solid var(--border);
        color: var(--text-2);
        font-family: var(--font-mono);
        font-size: 11px;
        text-transform: uppercase;
      }

      .bar-row,
      .data-row {
        height: 48px;
        opacity: 0;
        visibility: hidden;
      }

      .bar-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 7px;
        color: var(--text-2);
        font-family: var(--font-mono);
        font-size: 11px;
      }

      .bar-track {
        height: 8px;
        overflow: hidden;
        border-radius: 3px;
        background: var(--surface-3);
      }

      .bar-fill {
        display: block;
        width: 100%;
        height: 100%;
        border-radius: 3px;
        background: var(--accent);
        transform: scaleX(0);
        transform-origin: 0 50%;
      }

      .data-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 10px;
        border-bottom: 1px solid var(--border);
        color: var(--text-2);
        font-family: var(--font-mono);
        font-size: 11px;
      }

      .data-row:last-child {
        border-bottom: 0;
      }

      .data-row-label {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .data-row-value {
        color: var(--text);
        font-weight: 600;
      }

      .status-bar {
        min-height: 72px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 22px;
        flex: 0 0 auto;
        padding: 12px 5px 0;
        margin-top: 8px;
        border-top: 1px solid var(--border);
        color: var(--text-2);
        font-family: var(--font-mono);
        font-size: 12px;
      }

      .status-lines {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 3px;
      }

      .status-row {
        display: flex;
        align-items: center;
        gap: 7px;
        min-width: 0;
      }

      .status-project {
        overflow: hidden;
        color: var(--text);
        font-weight: 600;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .status-event {
        color: var(--text-2);
      }

      .status-check {
        color: var(--text-2);
        font-weight: 700;
      }

      .timeline-wrap {
        width: 410px;
      }

      .timeline-labels {
        display: flex;
        justify-content: space-between;
        margin-bottom: 6px;
        color: var(--text-2);
        font-size: 11px;
      }

      .timeline-track {
        height: 10px;
        overflow: hidden;
        border-radius: 3px;
        background: var(--surface-3);
      }

      .timeline-fill {
        display: block;
        width: 100%;
        height: 100%;
        border-radius: 3px;
        background: var(--accent);
        transform: scaleX(0);
        transform-origin: 0 50%;
      }

      .complete-pill {
        position: absolute;
        z-index: 8;
        right: 48px;
        bottom: 106px;
        padding: 10px 15px;
        border: 1px solid var(--border-strong);
        border-radius: 999px;
        background: var(--surface);
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 12px;
        opacity: 0;
        box-shadow: 0 8px 24px rgba(61, 57, 41, 0.1);
      }
    </style>
  </head>
  <body>
    <div
      id="root"
      data-composition-id="macaron-replay"
      data-start="0"
      data-duration="__REPLAY_DURATION__"
      data-framerate="30"
      data-width="1920"
      data-height="1080"
    >
      <section
        id="replay-shell"
        class="clip"
        data-start="0"
        data-duration="__REPLAY_DURATION__"
        data-track-index="0"
      >
        <div class="frame-fill">
          <aside class="sidebar">
            <div class="brand">
              <img class="brand-mark" src=".media/images/logo_001.svg" alt="" />
              <div>
                <div class="brand-name">Macaron</div>
                <div class="brand-sub">agent workspace</div>
              </div>
            </div>
            <nav class="nav">
              <div class="nav-item"><span>Workspaces</span><small>Projects and sessions</small></div>
              <div class="nav-item active"><span>Session replay</span><small id="sidebar-session">checkout-latency</small></div>
              <div class="nav-item"><span>Artifacts</span><small>Generated outputs</small></div>
            </nav>
            <div class="sidebar-section">
              <div class="sidebar-label">Agent</div>
              <div class="agent-row">
                <div id="agent-avatar" class="agent-avatar">E</div>
                <div>
                  <div id="agent-name" class="agent-name">EVE</div>
                  <div class="agent-role">coding agent</div>
                </div>
              </div>
            </div>
            <div class="sidebar-footer">
              <span class="runtime-status">runtime ready</span>
              <code>v1</code>
            </div>
          </aside>

          <main class="main">
            <header class="session-bar">
              <div class="session-bar-left">
                <span class="crumb-link">Workspaces</span>
                <span class="sep">&gt;</span>
                <span class="crumb-link">GenUI</span>
                <span class="sep">&gt;</span>
                <span id="session-id" class="session-id">checkout-latency</span>
                <span class="branch">replay/main</span>
              </div>
              <div class="session-bar-right">
                <span id="timecode" class="mono">00:00.0</span>
                <span class="live-state"><span class="live-dot"></span><span id="live-label">REPLAYING</span></span>
              </div>
            </header>

            <div class="workspace">
              <section class="thread-panel">
                <header class="panel-head">
                  <div>
                    <div class="panel-title">Session</div>
                    <div class="panel-subtitle">messages, tools, and render_ui</div>
                  </div>
                  <div id="trace-count" class="event-count">00 / 00</div>
                </header>
                <div class="feed-viewport">
                  <div class="session-head"><strong>~/macaron/checkout</strong><span>(24s replay)</span></div>
                  <div id="feed-stack" class="feed-stack"></div>
                </div>
              </section>

              <section class="preview-panel">
                <header class="panel-head">
                  <div>
                    <div class="panel-title">render_ui</div>
                    <div class="panel-subtitle">live GenUI preview</div>
                  </div>
                  <div class="preview-head-right">
                    <span id="stream-label">waiting</span>
                    <span class="genui-streaming">streaming</span>
                  </div>
                </header>
                <div class="preview-progress-track"><span id="preview-progress" class="preview-progress"></span></div>
                <div class="preview-canvas">
                  <div id="preview-empty" class="preview-empty">
                    <div><strong>Preview idle</strong><span>render_ui output will appear here</span></div>
                  </div>
                  <section id="genui-root" class="genui-root" aria-label="Incremental GenUI preview">
                    <div class="dashboard">
                      <div class="dashboard-topline">
                        <div id="dashboard-eyebrow" class="dashboard-eyebrow"></div>
                        <div id="dashboard-status" class="dashboard-status"></div>
                      </div>
                      <h2 id="dashboard-title" class="dashboard-title"></h2>
                      <div id="stats-grid" class="stats-grid"></div>
                      <div class="dashboard-body">
                        <section id="bars-section" class="data-section">
                          <div class="section-label">Signal</div>
                          <div id="bars-list"></div>
                        </section>
                        <section id="rows-section" class="data-section">
                          <div class="section-label">Details</div>
                          <div id="rows-list"></div>
                        </section>
                      </div>
                    </div>
                  </section>
                </div>
              </section>
            </div>

            <footer class="status-bar">
              <div class="status-lines">
                <div class="status-row"><span class="status-check">+</span><span id="status-project" class="status-project">Checkout latency review</span><span class="sep">|</span><span id="event-position" class="status-event">event 00 / 00</span></div>
                <div class="status-row"><span class="status-check">+</span><span>tools connected</span><span class="sep">|</span><span id="render-count">2 render_ui calls</span></div>
              </div>
              <div class="timeline-wrap">
                <div class="timeline-labels"><span>SESSION TIMELINE</span><span id="event-total">00 EVENTS</span></div>
                <div class="timeline-track"><span id="timeline-fill" class="timeline-fill"></span></div>
              </div>
            </footer>
            <div id="complete-pill" class="complete-pill">+ replay complete</div>
          </main>
        </div>
      </section>
    </div>

    <script>
      const replay = window.REPLAY_DATA;
      const events = replay.events;
      const renderEvents = events.filter((event) => event.type === "render_ui");
      const totalEvents = events.length;

      const create = (tag, className, text) => {
        const node = document.createElement(tag);
        if (className) node.className = className;
        if (text !== undefined) node.textContent = text;
        return node;
      };

      const formatTime = (seconds) => {
        const minutes = Math.floor(seconds / 60);
        const rest = (seconds % 60).toFixed(1).padStart(4, "0");
        return `${String(minutes).padStart(2, "0")}:${rest}`;
      };

      const eventLabel = (event) => {
        if (event.type === "tool") return event.name;
        if (event.type === "render_ui") return "render_ui";
        return event.type;
      };

      document.getElementById("session-id").textContent = replay.id;
      document.getElementById("sidebar-session").textContent = replay.id;
      document.getElementById("status-project").textContent = replay.title;
      document.getElementById("agent-name").textContent = replay.agent;
      document.getElementById("agent-avatar").textContent = replay.agent.slice(0, 1).toUpperCase();
      document.getElementById("event-total").textContent = `${String(totalEvents).padStart(2, "0")} EVENTS`;
      document.getElementById("render-count").textContent = `${renderEvents.length} render_ui calls`;

      const feedStack = document.getElementById("feed-stack");
      const eventNodes = [];
      const renderNodeById = new Map();

      function renderEvent(event) {
        const entry = create("article", `event-entry ${event.type}`);
        entry.id = `event-${event.id}`;

        if (event.type === "user") {
          entry.appendChild(create("span", "user-chev", ">"));
          entry.appendChild(create("div", "event-copy", event.text));
        } else if (event.type === "assistant") {
          entry.appendChild(create("div", "event-meta", "assistant"));
          entry.appendChild(create("div", "event-copy", event.text));
        } else if (event.type === "tool") {
          const head = create("div", "tool-head");
          head.appendChild(create("span", `tool-dot ${event.status || ""}`));
          head.appendChild(create("span", "tool-name", event.name));
          head.appendChild(create("span", "tool-input", `(${event.input})`));
          head.appendChild(create("span", "tool-time", formatTime(event.start)));
          entry.appendChild(head);
          const out = create("div", "tool-out");
          out.appendChild(create("span", "tool-rail", "|-"));
          out.appendChild(create("span", "tool-result", event.result));
          entry.appendChild(out);
        } else {
          const head = create("div", "genui-event-head");
          head.appendChild(create("span", "genui-event-dot"));
          head.appendChild(create("span", "genui-event-label", "render_ui"));
          const code = create("code", "genui-event-code", "");
          head.appendChild(code);
          head.appendChild(create("span", "genui-streaming", "streaming"));
          entry.appendChild(head);
          const track = create("div", "event-progress-track");
          const progress = create("span", "event-progress");
          track.appendChild(progress);
          entry.appendChild(track);
          renderNodeById.set(event.id, { code, progress });
        }

        feedStack.appendChild(entry);
        eventNodes.push(entry);
      }

      events.forEach(renderEvent);

      const allFrames = renderEvents.flatMap((event) => event.stream);
      const slotCount = (key) => Math.max(0, ...allFrames.map((frame) => (frame.preview[key] || []).length));
      const statSlots = [];
      const barSlots = [];
      const rowSlots = [];

      const statsGrid = document.getElementById("stats-grid");
      for (let index = 0; index < slotCount("stats"); index += 1) {
        const card = create("div", "stat-card");
        const label = create("div", "stat-label");
        const value = create("div", "stat-value");
        card.append(label, value);
        statsGrid.appendChild(card);
        statSlots.push({ card, label, value });
      }

      const barsList = document.getElementById("bars-list");
      for (let index = 0; index < slotCount("bars"); index += 1) {
        const row = create("div", "bar-row");
        const meta = create("div", "bar-meta");
        const label = create("span");
        const value = create("span");
        meta.append(label, value);
        const track = create("div", "bar-track");
        const fill = create("span", "bar-fill");
        track.appendChild(fill);
        row.append(meta, track);
        barsList.appendChild(row);
        barSlots.push({ row, label, value, fill });
      }

      const rowsList = document.getElementById("rows-list");
      for (let index = 0; index < slotCount("rows"); index += 1) {
        const row = create("div", "data-row");
        const label = create("span", "data-row-label");
        const value = create("span", "data-row-value");
        row.append(label, value);
        rowsList.appendChild(row);
        rowSlots.push({ row, label, value });
      }

      window.__timelines = window.__timelines || {};
      const tl = gsap.timeline({ paused: true });
      const timelineFill = document.getElementById("timeline-fill");
      const previewProgress = document.getElementById("preview-progress");
      const previewEmpty = document.getElementById("preview-empty");
      const genuiRoot = document.getElementById("genui-root");
      const streamLabel = document.getElementById("stream-label");
      const eventPosition = document.getElementById("event-position");
      const traceCount = document.getElementById("trace-count");
      const timecode = document.getElementById("timecode");
      const dashboardEyebrow = document.getElementById("dashboard-eyebrow");
      const dashboardStatus = document.getElementById("dashboard-status");
      const dashboardTitle = document.getElementById("dashboard-title");
      const barsSection = document.getElementById("bars-section");
      const rowsSection = document.getElementById("rows-section");

      tl.fromTo(".sidebar", { x: -260 }, { x: 0, duration: 0.52, ease: "power3.out" }, 0.08);
      tl.fromTo(".session-bar", { opacity: 0, y: -14 }, { opacity: 1, y: 0, duration: 0.42, ease: "power3.out" }, 0.14);
      tl.fromTo(".workspace", { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.48, ease: "circ.out" }, 0.18);
      tl.fromTo(".status-bar", { opacity: 0, y: 14 }, { opacity: 1, y: 0, duration: 0.4, ease: "sine.out" }, 0.24);
      tl.fromTo(timelineFill, { scaleX: 0 }, { scaleX: 1, duration: replay.duration, ease: "none" }, 0);

      const clock = { t: 0 };
      let lastTick = -1;
      tl.to(clock, {
        t: replay.duration,
        duration: replay.duration,
        ease: "none",
        onUpdate: () => {
          const tick = Math.floor(clock.t * 10);
          if (tick !== lastTick) {
            timecode.textContent = formatTime(clock.t);
            lastTick = tick;
          }
        },
      }, 0);

      events.forEach((event, index) => {
        const node = eventNodes[index];
        const direction = index % 2 === 0 ? 14 : -10;
        tl.fromTo(node, { opacity: 0, x: direction }, { opacity: 1, x: 0, duration: 0.34, ease: "power3.out" }, event.start);

        tl.set(eventPosition, { innerText: `event ${String(index + 1).padStart(2, "0")} / ${String(totalEvents).padStart(2, "0")}` }, event.start);
        tl.set(traceCount, { innerText: `${String(index + 1).padStart(2, "0")} / ${String(totalEvents).padStart(2, "0")}` }, event.start);
      });

      let previewMounted = false;
      let visibleStats = 0;
      let visibleBars = 0;
      let visibleRows = 0;
      let barsMounted = false;
      let rowsMounted = false;

      function updateStats(stats, at) {
        stats.forEach((stat, index) => {
          const slot = statSlots[index];
          tl.set(slot.label, { innerText: stat.label }, at);
          tl.set(slot.value, { innerText: stat.value }, at);
          tl.set(slot.card, { className: `stat-card ${stat.tone || ""}` }, at);
          if (index >= visibleStats) {
            tl.fromTo(slot.card, { autoAlpha: 0, y: 10 }, { autoAlpha: 1, y: 0, duration: 0.32, ease: "power3.out" }, at + index * 0.05);
          }
        });
        visibleStats = Math.max(visibleStats, stats.length);
      }

      function updateBars(bars, at) {
        if (bars.length && !barsMounted) {
          tl.fromTo(barsSection, { autoAlpha: 0, y: 10 }, { autoAlpha: 1, y: 0, duration: 0.3, ease: "power3.out" }, at);
          barsMounted = true;
        }
        bars.forEach((bar, index) => {
          const slot = barSlots[index];
          const ratio = Math.max(0, Math.min(1, bar.value / bar.max));
          tl.set(slot.label, { innerText: bar.label }, at);
          tl.set(slot.value, { innerText: `${bar.value}%` }, at);
          if (index >= visibleBars) {
            tl.fromTo(slot.row, { autoAlpha: 0, x: -8 }, { autoAlpha: 1, x: 0, duration: 0.28, ease: "sine.out" }, at + index * 0.05);
            tl.fromTo(slot.fill, { scaleX: 0 }, { scaleX: ratio, duration: 0.42, ease: "circ.out" }, at + 0.06 + index * 0.05);
          } else {
            tl.to(slot.fill, { scaleX: ratio, duration: 0.34, ease: "circ.out" }, at);
          }
        });
        visibleBars = Math.max(visibleBars, bars.length);
      }

      function updateRows(rows, at) {
        if (rows.length && !rowsMounted) {
          tl.fromTo(rowsSection, { autoAlpha: 0, y: 10 }, { autoAlpha: 1, y: 0, duration: 0.3, ease: "power3.out" }, at);
          rowsMounted = true;
        }
        rows.forEach((item, index) => {
          const slot = rowSlots[index];
          tl.set(slot.label, { innerText: item.label }, at);
          tl.set(slot.value, { innerText: item.value }, at);
          if (index >= visibleRows) {
            tl.fromTo(slot.row, { autoAlpha: 0, x: 8 }, { autoAlpha: 1, x: 0, duration: 0.28, ease: "sine.out" }, at + index * 0.05);
          }
        });
        visibleRows = Math.max(visibleRows, rows.length);
      }

      renderEvents.forEach((event, renderIndex) => {
        const renderNode = renderNodeById.get(event.id);
        const codeDriver = { value: 0 };
        tl.to(codeDriver, {
          value: event.code.length,
          duration: Math.max(1, event.duration - 0.5),
          ease: "none",
          onUpdate: () => {
            const streamed = event.code.slice(0, Math.floor(codeDriver.value));
            renderNode.code.textContent = streamed.length > 54 ? `...${streamed.slice(-51)}` : streamed;
          },
        }, event.start + 0.14);
        tl.fromTo(renderNode.progress, { scaleX: 0 }, { scaleX: 1, duration: event.duration - 0.26, ease: "none" }, event.start + 0.12);
        tl.set(previewProgress, { scaleX: 0 }, event.start);
        tl.to(previewProgress, { scaleX: 1, duration: event.duration - 0.18, ease: "none" }, event.start + 0.08);
        tl.set(streamLabel, { innerText: `call ${String(renderIndex + 1).padStart(2, "0")}` }, event.start);

        if (!previewMounted) {
          tl.to(previewEmpty, { autoAlpha: 0, duration: 0.18, ease: "power1.out" }, event.start);
          tl.fromTo(genuiRoot, { autoAlpha: 0, y: 8 }, { autoAlpha: 1, y: 0, duration: 0.34, ease: "power3.out" }, event.stream[0].at);
          previewMounted = true;
        }

        event.stream.forEach((frame) => {
          const preview = frame.preview;
          const at = frame.at;
          tl.set(streamLabel, { innerText: frame.label.toLowerCase() }, at);
          tl.set(dashboardEyebrow, { innerText: preview.eyebrow || "" }, at);
          tl.set(dashboardStatus, { innerText: preview.status || "Streaming" }, at);
          tl.set(dashboardTitle, { innerText: preview.title || "" }, at);
          updateStats(preview.stats || [], at);
          updateBars(preview.bars || [], at);
          updateRows(preview.rows || [], at);
        });
      });

      const closeAt = replay.duration - replay.outroDuration;
      tl.fromTo("#complete-pill", { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.32, ease: "power3.out" }, closeAt);
      tl.to(".live-dot", { backgroundColor: "#5a8b5a", scale: 1.25, duration: 0.22, ease: "power2.out" }, closeAt);
      tl.set("#live-label", { innerText: "COMPLETE" }, closeAt);

      window.__timelines["macaron-replay"] = tl;
    </script>
  </body>
</html>
