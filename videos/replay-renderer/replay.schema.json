{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macaron.dev/schemas/replay-video.json",
  "title": "Macaron replay video input",
  "type": "object",
  "required": ["version", "id", "title", "agent", "targetDuration", "events"],
  "properties": {
    "version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string" },
    "agent": { "type": "string", "minLength": 1 },
    "targetDuration": { "type": "number", "minimum": 8, "maximum": 180 },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/message" },
          { "$ref": "#/$defs/tool" },
          { "$ref": "#/$defs/renderUi" }
        ]
      }
    }
  },
  "$defs": {
    "base": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string" }
      }
    },
    "message": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["text"],
          "properties": {
            "type": { "enum": ["user", "assistant"] },
            "text": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "tool": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "name", "input", "result"],
          "properties": {
            "type": { "const": "tool" },
            "name": { "type": "string", "minLength": 1 },
            "input": { "type": "string" },
            "result": { "type": "string" },
            "status": { "enum": ["ok", "warning", "error"] }
          }
        }
      ]
    },
    "renderUi": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "code", "stream"],
          "properties": {
            "type": { "const": "render_ui" },
            "code": { "type": "string", "minLength": 20 },
            "stream": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "required": ["label", "preview"],
                "properties": {
                  "label": { "type": "string", "minLength": 1 },
                  "preview": {
                    "type": "object",
                    "required": ["eyebrow", "title"],
                    "properties": {
                      "eyebrow": { "type": "string" },
                      "title": { "type": "string" },
                      "status": { "type": "string" },
                      "stats": { "type": "array" },
                      "bars": { "type": "array" },
                      "rows": { "type": "array" }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
