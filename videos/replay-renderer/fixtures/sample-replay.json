{
  "version": 1,
  "id": "checkout-latency",
  "title": "Checkout latency review",
  "subtitle": "Agent session replay / streaming GenUI",
  "agent": "EVE",
  "targetDuration": 24,
  "events": [
    {
      "id": "event-user",
      "type": "user",
      "text": "Trace the checkout slowdown, patch the hot path, and show me the result as a compact incident dashboard."
    },
    {
      "id": "event-plan",
      "type": "assistant",
      "text": "I will inspect the route, establish a baseline, then render the evidence before and after the fix."
    },
    {
      "id": "event-read",
      "type": "tool",
      "name": "Read",
      "input": "server/src/routes/checkout.ts",
      "result": "Loaded 214 lines / cache guard found after pricing lookup",
      "status": "ok"
    },
    {
      "id": "event-test",
      "type": "tool",
      "name": "Bash",
      "input": "pnpm test checkout --reporter=dot",
      "result": "18 passed / baseline p95 842 ms",
      "status": "warning"
    },
    {
      "id": "event-ui-baseline",
      "type": "render_ui",
      "code": "export default function LatencyOverview(){return <Dashboard title=\"Checkout latency\" stats={stats} bars={regions} rows={traces} />} ",
      "stream": [
        {
          "label": "shell",
          "preview": {
            "eyebrow": "LIVE BASELINE",
            "title": "Checkout latency",
            "status": "Streaming"
          }
        },
        {
          "label": "metrics",
          "preview": {
            "eyebrow": "LIVE BASELINE",
            "title": "Checkout latency",
            "status": "Streaming",
            "stats": [
              { "label": "p50", "value": "188 ms", "tone": "good" },
              { "label": "p95", "value": "842 ms", "tone": "bad" },
              { "label": "errors", "value": "0.7%", "tone": "warn" }
            ]
          }
        },
        {
          "label": "regions",
          "preview": {
            "eyebrow": "LIVE BASELINE",
            "title": "Checkout latency",
            "status": "Streaming",
            "stats": [
              { "label": "p50", "value": "188 ms", "tone": "good" },
              { "label": "p95", "value": "842 ms", "tone": "bad" },
              { "label": "errors", "value": "0.7%", "tone": "warn" }
            ],
            "bars": [
              { "label": "us-east", "value": 84, "max": 100 },
              { "label": "eu-west", "value": 58, "max": 100 },
              { "label": "ap-south", "value": 43, "max": 100 }
            ]
          }
        },
        {
          "label": "traces",
          "preview": {
            "eyebrow": "LIVE BASELINE",
            "title": "Checkout latency",
            "status": "Ready",
            "stats": [
              { "label": "p50", "value": "188 ms", "tone": "good" },
              { "label": "p95", "value": "842 ms", "tone": "bad" },
              { "label": "errors", "value": "0.7%", "tone": "warn" }
            ],
            "bars": [
              { "label": "us-east", "value": 84, "max": 100 },
              { "label": "eu-west", "value": 58, "max": 100 },
              { "label": "ap-south", "value": 43, "max": 100 }
            ],
            "rows": [
              { "label": "pricing.lookup", "value": "491 ms", "state": "slow" },
              { "label": "inventory.reserve", "value": "119 ms", "state": "ok" },
              { "label": "payment.intent", "value": "104 ms", "state": "ok" }
            ]
          }
        }
      ]
    },
    {
      "id": "event-edit",
      "type": "tool",
      "name": "Edit",
      "input": "Move cache lookup ahead of pricing hydration",
      "result": "Updated checkout.ts / added stale-key regression test",
      "status": "ok"
    },
    {
      "id": "event-verify",
      "type": "tool",
      "name": "Bash",
      "input": "pnpm test checkout && pnpm bench checkout",
      "result": "19 passed / p95 842 ms -> 236 ms",
      "status": "ok"
    },
    {
      "id": "event-summary",
      "type": "assistant",
      "text": "The cache guard now bypasses the expensive hydration path. Tests pass and p95 is down by 72%."
    },
    {
      "id": "event-ui-result",
      "type": "render_ui",
      "code": "export default function ReleaseStatus(){return <Dashboard title=\"Patch verified\" stats={improvement} bars={checks} rows={changes} />} ",
      "stream": [
        {
          "label": "shell",
          "preview": {
            "eyebrow": "VERIFICATION",
            "title": "Patch verified",
            "status": "Streaming"
          }
        },
        {
          "label": "result",
          "preview": {
            "eyebrow": "VERIFICATION",
            "title": "Patch verified",
            "status": "Streaming",
            "stats": [
              { "label": "p95", "value": "236 ms", "tone": "good" },
              { "label": "change", "value": "-72%", "tone": "good" },
              { "label": "tests", "value": "19/19", "tone": "good" }
            ]
          }
        },
        {
          "label": "checks",
          "preview": {
            "eyebrow": "VERIFICATION",
            "title": "Patch verified",
            "status": "Streaming",
            "stats": [
              { "label": "p95", "value": "236 ms", "tone": "good" },
              { "label": "change", "value": "-72%", "tone": "good" },
              { "label": "tests", "value": "19/19", "tone": "good" }
            ],
            "bars": [
              { "label": "unit", "value": 100, "max": 100 },
              { "label": "integration", "value": 100, "max": 100 },
              { "label": "benchmark", "value": 92, "max": 100 }
            ]
          }
        },
        {
          "label": "changes",
          "preview": {
            "eyebrow": "VERIFICATION",
            "title": "Patch verified",
            "status": "Ready",
            "stats": [
              { "label": "p95", "value": "236 ms", "tone": "good" },
              { "label": "change", "value": "-72%", "tone": "good" },
              { "label": "tests", "value": "19/19", "tone": "good" }
            ],
            "bars": [
              { "label": "unit", "value": 100, "max": 100 },
              { "label": "integration", "value": 100, "max": 100 },
              { "label": "benchmark", "value": 92, "max": 100 }
            ],
            "rows": [
              { "label": "checkout.ts", "value": "+8 -5", "state": "changed" },
              { "label": "checkout.test.ts", "value": "+24", "state": "changed" },
              { "label": "CI", "value": "passed", "state": "ok" }
            ]
          }
        }
      ]
    }
  ]
}
