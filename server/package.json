{
  "name": "@macaron/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "bundle": "bun build src/index.ts --target=node --format=esm --outfile=dist/index.js --packages=external",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.196",
    "@fastify/static": "^8.0.0",
    "@genui/diagnostics": "https://pkg.pr.new/MindLab-Research/macaron-genui-demo/@genui/diagnostics@2c00556",
    "@macaron/shared": "*",
    "fastify": "^5.2.0",
    "typescript": "^5.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0"
  }
}
