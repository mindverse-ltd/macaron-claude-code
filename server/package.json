{
  "name": "@macaron/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "bundle": "bun build src/index.ts --target=node --format=esm --outfile=dist/index.js --packages=external",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\" \"test/*.test.ts\""
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.2.1",
    "@anthropic-ai/claude-agent-sdk": "^0.3.196",
    "@fastify/static": "^8.0.0",
    "@genui/diagnostics": "https://pkg.pr.new/MindLab-Research/macaron-genui-demo/@genui/diagnostics@7c845c8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "^0.142.5",
    "@unocss/autocomplete": "^66.7.5",
    "@unocss/core": "^66.7.5",
    "@unocss/preset-wind3": "^66.7.5",
    "croner": "^10.0.1",
    "fastify": "^5.2.0",
    "ignore": "^7.0.5",
    "node-pty": "^1.1.0",
    "typescript": "^5.7.0",
    "unocss-preset-animations": "^1.3.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@macaron/shared": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.19.0"
  }
}
