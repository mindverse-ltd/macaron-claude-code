{
  "name": "mcc",
  "version": "0.1.0",
  "description": "Macaron Claude Code WebUI — GenUI tooling and plugin manifests. Self-contained launcher, prebuilt server + web bundles.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web -c blue,magenta \"pnpm --filter @macaron/server dev\" \"pnpm --filter @macaron/web dev\"",
    "build": "pnpm --filter @macaron/shared build && pnpm --filter @macaron/server build && pnpm --filter @macaron/web build",
    "build:web": "pnpm --filter @macaron/shared build && pnpm --filter @macaron/web build",
    "build:server": "pnpm --filter @macaron/shared build && pnpm --filter @macaron/server build",
    "start": "node server/dist/index.js",
    "bundle": "pnpm --filter @macaron/server bundle",
    "prepack": "pnpm --filter @macaron/shared build && pnpm --filter @macaron/server bundle && pnpm --filter @macaron/web build",
    "typecheck": "pnpm --filter @macaron/shared typecheck && pnpm --filter @macaron/server typecheck && pnpm --filter @macaron/web typecheck",
    "replay:test": "node --test scripts/replay/*.test.mjs",
    "replay:render": "pnpm build:web && node scripts/replay/render.mjs"
  },
  "bin": {
    "mcc": "./bin/mcc.mjs"
  },
  "files": [
    "bin",
    "server/dist/index.js",
    "web/dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.196",
    "@fastify/static": "^8.0.0",
    "@genui/diagnostics": "https://pkg.pr.new/MindLab-Research/macaron-genui-demo/@genui/diagnostics@7c845c8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "^0.142.5",
    "@unocss/autocomplete": "^66.7.5",
    "@unocss/core": "^66.7.5",
    "@unocss/preset-wind3": "^66.7.5",
    "croner": "^10.0.1",
    "fastify": "^5.2.0",
    "ignore": "^7.0.5",
    "node-pty": "^1.1.0",
    "typescript": "^5.7.0",
    "unocss-preset-animations": "^1.3.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "pkg-pr-new": "^0.0.75",
    "playwright-core": "^1.61.1"
  }
}
