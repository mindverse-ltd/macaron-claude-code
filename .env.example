# Copy to .env (or export in your shell) before starting the server.
# .env is git-ignored — never commit real values.

# Optional OpenAI-compatible endpoint for custom providers.
MACARON_API_BASE=https://api.example.com/v1
MACARON_API_KEY=<api-key>

# Optional — override the model id sent to the custom provider.
# MACARON_MODEL=<model-id>

# Optional — server bind port/host.
# MACARON_PORT=7878
# MACARON_HOST=127.0.0.1

# Optional — shared token that gates the API when the server is reachable from
# the network. Localhost requests are never challenged, so leaving this unset
# keeps local use frictionless. If you bind MACARON_HOST to a non-loopback
# address (e.g. 0.0.0.0) without setting this, the server auto-generates a
# token at boot and prints it — set your own here for a stable value.
# MACARON_AUTH_TOKEN=<a-long-random-string>

# Optional — where the New Project wizard creates dirs and clones repos.
# MACARON_PROJECTS_ROOT=/Users/you/macaron-projects

# Optional — server log level (default: info).
# MACARON_LOG_LEVEL=debug

# Optional — voice input (speech-to-text). The mic button stays hidden until
# MACARON_STT_API_KEY is set. Any OpenAI-compatible /audio/transcriptions host.
# MACARON_STT_API_KEY=<your-stt-api-key>
# MACARON_STT_BASE_URL=https://api.openai.com/v1
# MACARON_STT_MODEL=whisper-1
# MACARON_STT_LANGUAGE=en
