# Deps
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
*.tsbuildinfo

# EXCEPT: web/dist and server/dist ship as prebuilt artifacts so the
# plugin marketplace flow (`codex plugin marketplace add …`, `/plugin
# install`) works without a client-side npm install + build. Rebuild
# with `npm run build` before committing when web/src, server/src or
# shared/src changed.
!web/dist/
!web/dist/**
!server/dist/
!server/dist/**

# Env / secrets
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*~

# Logs & tmp
*.log
/tmp/
.cache/

# Claude Code local
.claude/settings.local.json
